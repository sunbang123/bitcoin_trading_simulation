SPRING_PROFILES_ACTIVE=supabase

# Copy the Session Pooler JDBC values from the Supabase Connect dialog.
# EC2 instances without IPv6 should use Session Pooler mode on port 5432.
SUPABASE_DB_URL=jdbc:postgresql://YOUR_SESSION_POOLER_HOST:5432/postgres?sslmode=require
SUPABASE_DB_USER=trading_app.nxrajxtplwapwurmiarc
SUPABASE_DB_PASSWORD=REPLACE_WITH_A_STRONG_DATABASE_PASSWORD

# Generate a random Base64 secret with at least 32 bytes for production.
JWT_SECRET=REPLACE_WITH_A_RANDOM_BASE64_SECRET
CORS_ALLOWED_ORIGINS=https://YOUR_FRONTEND_DOMAIN

DB_POOL_SIZE=5
DB_MIN_IDLE=1
